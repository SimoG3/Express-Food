                <tr><td colSpan={8} className="text-center py-14 text-gray-400">
                  <Package size={36} className="mx-auto mb-2" style={{ color: '#e5e5e5' }} />
                  <p>Aucun produit trouvé</p>
                </td></tr>
              )}
            </tbody>
          </table>
        </div>
      </div>
    </>
  );
}

