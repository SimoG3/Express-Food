  id:           string;
  name:         string;
  category:     string;
  subcategory?: string;
  price:        number;   // Prix TTC (displayed to normal clients)
  prixHT?:      number;   // Prix HT (for admin reference)
  tva?:         string;   // '5.5%' | '20%'
  unit:         string;
  image:        string;
  variantId:    string;
  inStock:      boolean;
  description:  string;
  discount?:    number;   // percentage e.g. 15 = 15% off
